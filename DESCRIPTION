Package: geonuts
Type: Package
Title: Identification and Visualisation of European NUTS Regions from
        Geolocations
Version: 1.0.1
Authors@R: 
    c(
      person("Attila I.", "Katona", 
             email = "katona.attila@gtk.uni-pannon.hu", 
             role = c("aut", "cre")),
      person("Marcell T.", "Kurbucz", 
             email = "m.kurbucz@ucl.ac.uk", 
